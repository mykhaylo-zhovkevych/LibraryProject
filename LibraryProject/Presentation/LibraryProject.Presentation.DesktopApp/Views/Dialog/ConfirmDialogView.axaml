<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryProject.Presentation.DesktopApp.ViewModels.Dialog"
             mc:Ignorable="d" 
             MinWidth="300"
             x:Class="LibraryProject.Presentation.DesktopApp.Views.Dialog.ConfirmDialogViewModel"
             x:DataType="vm:ConfirmDialogViewModel">


    <Design.DataContext><vm:ConfirmDialogViewModel></vm:ConfirmDialogViewModel></Design.DataContext>

  <!-- Main Dialog Window-->
    <Border Background="Red" CornerRadius="20" ClipToBounds="True" Margin=" 10" BorderThickness="1">
		
        <StackPanel>
			
            <!-- Title-->
            <Border Background="Black" CornerRadius="20 0">
				
                <TextBlock Text="{Binding Title}" Padding="10" Foreground="White" FontSize="20" HorizontalAlignment="Center" />

            </Border>

            <!-- Description --> 

            <Border Padding="20">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal">
					    <TextBlock TextWrapping="Wrap" Text="{Binding Message}" FontSize="16" />
                    </StackPanel>
                    
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="20">
						<Button Content="{Binding CancelText}" Command="{Binding ConfirmText}" Foreground="DarkRed"></Button>
                        <Button Content="{Binding ConfirmText}" Command="{Binding ConfirmCommand}" Foreground="DarkGreen"></Button>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
