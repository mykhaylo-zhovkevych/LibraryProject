<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:views="using:LibraryProject.Presentation.DesktopApp.Views"
             x:Class="LibraryProject.Presentation.DesktopApp.Views.ManagementView">


<Grid RowDefinitions="Auto,Auto,Auto,*">

    <TextBlock Grid.Row="0" Text="Verwaltung"/>

    <TextBlock Grid.Row="1" Text="Systemverwaltung und ‹bersicht"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal">

      <Button Content="Uebersicht" Command="{Binding ShowOverviewCommand}" />

      <Button Content="Buecher" Command="{Binding ShowBooksCommand}" />

      <Button Content="Benutzer" Command="{Binding ShowUsersCommand}" />

      <Button Content="Einstellungen" Command="{Binding ShowSettingsCommand}" />
    </StackPanel>

    <ContentControl Grid.Row="3" Content="{Binding CurrentSection}" />

  </Grid>


</UserControl>
