<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryProject.Presentation.DesktopApp.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LibraryProject.Presentation.DesktopApp.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    
    <Border 
    MaxWidth="400" 
    MaxHeight="600" 
    CornerRadius="8" 
    Padding="8" 
    Background="#f5f5f5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Icon -->

            <TextBlock FontSize="24" Text="Bibliothek Verwaltung" HorizontalAlignment="Center"/>
            <StackPanel>
                <Label Content="Anmeldung" Margin="0,10,0,0"/>
                <!--<Label FontFamily="{DynamicResource Phosphor}" Content="&#xe2c2;"/>-->
                <Label Content="Melden Sie sich mit Ihren Zugangsdaten an" Margin="0,0,0,10" />
            </StackPanel>

            <!--User Id-->
            <StackPanel>
				<TextBlock Text="User Id" FontWeight="SemiBold" ></TextBlock>
                <TextBox BorderThickness="0" Background="#f3f3f5" Watermark="Enter your user id" Padding="8"></TextBox>
            </StackPanel>
            <!--Name-->
            <StackPanel>
				<TextBlock Text="Name" FontWeight="SemiBold" ></TextBlock>
                <TextBox BorderThickness="0" Background="#f3f3f5" Watermark="Enter your name" Padding="8"></TextBox>
            </StackPanel>
            <!--Password-->
            <StackPanel>
				<TextBlock Text="Password" FontWeight="SemiBold" ></TextBlock>
                <TextBox BorderThickness="0" Background="#f3f3f5" PasswordChar="*" Watermark="Enter your password" Padding="8"></TextBox>
            </StackPanel>

            <!--Errro Text Block-->

            <TextBlock Text="Error Message" FontSize="12" Foreground="Red" HorizontalAlignment="Center" />

            <!--TODO: Add on hover effect -->
            <Button Content="Login"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Background="#030213" />

            <Button Content="Neues Konto erstellen"
                    HorizontalAlignment="Stretch" />

        </StackPanel>		
    </Border>

</UserControl>
