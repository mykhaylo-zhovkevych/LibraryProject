<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryProject.Presentation.DesktopApp.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LibraryProject.Presentation.DesktopApp.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    <Border 
    MaxWidth="400" 
    MaxHeight="600" 
    CornerRadius="8" 
    Padding="8" 
    Background="#f5f5f5">

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Icon -->
            
            <StackPanel Classes="Intro"> 
                <TextBlock FontSize="24" Text="Bibliothek Verwaltung" HorizontalAlignment="Center"/>
                <TextBlock Text="Willkommen zurueck" HorizontalAlignment="Center"></TextBlock>
            </StackPanel>

                <Label Content="Anmeldung" Margin="0,10,0,0"/>
                <!--<Label FontFamily="{DynamicResource Phosphor}" Content="&#xe2c2;"/>-->
                <Label Content="Melden Sie sich mit Ihren Zugangsdaten an" Margin="0,0,0,10" />

            <!--User Id-->
				<TextBlock Text="User Id" FontWeight="SemiBold" ></TextBlock>
                <TextBox BorderThickness="0" Background="#f3f3f5" Watermark="Benutzer Id" Padding="8" Text="{Binding UserId}"></TextBox>
            <!--Name-->
           
				<TextBlock Text="Name" FontWeight="SemiBold" ></TextBlock>
                <TextBox BorderThickness="0" Background="#f3f3f5" Watermark="Ihr vollständiger Name" Padding="8" Text="{Binding Name}"></TextBox>
            <!--Password-->

				<TextBlock Text="Password" FontWeight="SemiBold" ></TextBlock>
                <TextBox BorderThickness="0" Background="#f3f3f5" PasswordChar="*" Watermark="Mindestens 8 Zeichnen" Padding="8" Text="{Binding Password}"></TextBox>

            <!--Errro Text Block-->
            <StackPanel Margin="10">
                <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="Red" HorizontalAlignment="Center" />
            </StackPanel>

            <!--TODO: Add on hover effect -->
            <Button Content="Login"
                    Command="{Binding TryToLoginAsync}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="3"
                    Margin="0,10,0,5"/>

           <!-- <ProgressBar Height="4" IsIndeterminate="True"></ProgressBar>-->
            <Button Content="Neues Konto erstellen"
                    Command="{Binding NavigateToRegister}"
                    HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center"
                    Padding="3"
                    Margin="0,5,0,5"/>

        </StackPanel>		
    </Border>

</UserControl>
