<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:vm="using:LibraryProject.Presentation.DesktopApp.ViewModels"
             d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LibraryProject.Presentation.DesktopApp.Views.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <Design.DataContext>
        <vm:RegisterViewModel/>
    </Design.DataContext>


    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <TextBlock FontSize="24" Text="Register View" />
	    <Button Command="{Binding NavigateToLoginCommand}" Content="Go to Register"></Button>
	
    </StackPanel>
    

</UserControl>
